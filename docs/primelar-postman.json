{
  "info": {
    "name": "PrimeLar API",
    "description": "Coleção completa da API REST do PrimeLar",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"maria@primelar.com\",\n  \"password\": \"Senha@123\"\n}"
            }
          }
        },
        {
          "name": "Registrar (sempre cria USER)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"firstname\": \"João\",\n  \"lastname\": \"Silva\",\n  \"email\": \"joao@email.com\",\n  \"password\": \"Senha@123\"\n}"
            }
          }
        },
        {
          "name": "Esqueci a senha",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/forgot-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "forgot-password"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"usuario@email.com\"\n}"
            }
          }
        },
        {
          "name": "Redefinir senha",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/reset-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "reset-password"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"token\": \"TOKEN_RECEBIDO_NO_EMAIL\",\n  \"novaSenha\": \"novaSenha1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Password Reset (rota alternativa)",
      "item": [
        {
          "name": "Esqueci a senha",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/password/forgot",
              "host": ["{{base_url}}"],
              "path": ["password", "forgot"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"usuario@email.com\"\n}"
            }
          }
        },
        {
          "name": "Redefinir senha",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/password/reset",
              "host": ["{{base_url}}"],
              "path": ["password", "reset"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"token\": \"TOKEN_RECEBIDO_NO_EMAIL\",\n  \"newPassword\": \"novaSenha1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Imóveis",
      "item": [
        {
          "name": "Listar todos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/imoveis",
              "host": ["{{base_url}}"],
              "path": ["imoveis"]
            },
            "header": []
          }
        },
        {
          "name": "Buscar por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/imoveis/1",
              "host": ["{{base_url}}"],
              "path": ["imoveis", "1"]
            },
            "header": []
          }
        },
        {
          "name": "Cadastrar (ADMIN)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/imoveis",
              "host": ["{{base_url}}"],
              "path": ["imoveis"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"titulo\": \"Apartamento 3 quartos Centro\",\n  \"descricao\": \"Apartamento amplo com varanda, próximo ao metrô.\",\n  \"preco\": 350000.00,\n  \"cidade\": \"São Paulo\",\n  \"bairro\": \"Centro\",\n  \"endereco\": \"Rua das Flores, 100, Apto 42\",\n  \"quartos\": 3,\n  \"banheiros\": 2,\n  \"vagas\": 1,\n  \"caminhoImagem\": \"https://exemplo.com/imagem.jpg\"\n}"
            }
          }
        },
        {
          "name": "Atualizar (ADMIN)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/imoveis/1",
              "host": ["{{base_url}}"],
              "path": ["imoveis", "1"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"titulo\": \"Apartamento 3 quartos Centro — Atualizado\",\n  \"descricao\": \"Descrição atualizada.\",\n  \"preco\": 370000.00,\n  \"cidade\": \"São Paulo\",\n  \"bairro\": \"Centro\",\n  \"endereco\": \"Rua das Flores, 100, Apto 42\",\n  \"quartos\": 3,\n  \"banheiros\": 2,\n  \"vagas\": 2,\n  \"caminhoImagem\": \"https://exemplo.com/imagem-nova.jpg\"\n}"
            }
          }
        },
        {
          "name": "Excluir (ADMIN)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/imoveis/1",
              "host": ["{{base_url}}"],
              "path": ["imoveis", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Cadastrar com imagem (ADMIN)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/imoveis",
              "host": ["{{base_url}}"],
              "path": ["imoveis"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "titulo",    "value": "Apartamento 3 quartos Centro",                           "type": "text" },
                { "key": "descricao", "value": "Apartamento amplo com varanda, próximo ao metrô.",       "type": "text" },
                { "key": "preco",     "value": "350000.00",                                              "type": "text" },
                { "key": "cidade",    "value": "São Paulo",                                              "type": "text" },
                { "key": "bairro",    "value": "Centro",                                                 "type": "text" },
                { "key": "endereco",  "value": "Rua das Flores, 100, Apto 42",                           "type": "text" },
                { "key": "quartos",   "value": "3",                                                      "type": "text" },
                { "key": "banheiros", "value": "2",                                                      "type": "text" },
                { "key": "vagas",     "value": "1",                                                      "type": "text" },
                { "key": "imagem",    "src": "",                                                         "type": "file" }
              ]
            }
          }
        },
        {
          "name": "Atualizar com imagem (ADMIN)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/imoveis/1",
              "host": ["{{base_url}}"],
              "path": ["imoveis", "1"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "titulo",    "value": "Apartamento 3 quartos Centro — Atualizado",              "type": "text" },
                { "key": "descricao", "value": "Descrição atualizada.",                                  "type": "text" },
                { "key": "preco",     "value": "370000.00",                                              "type": "text" },
                { "key": "cidade",    "value": "São Paulo",                                              "type": "text" },
                { "key": "bairro",    "value": "Centro",                                                 "type": "text" },
                { "key": "endereco",  "value": "Rua das Flores, 100, Apto 42",                           "type": "text" },
                { "key": "quartos",   "value": "3",                                                      "type": "text" },
                { "key": "banheiros", "value": "2",                                                      "type": "text" },
                { "key": "vagas",     "value": "2",                                                      "type": "text" },
                { "key": "imagem",    "src": "",                                                         "type": "file" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Favoritos",
